# Server
PORT=5001
NODE_ENV=development

# Database (port 5433 = docker-compose, port 5432 = local PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/autospec_db

# JWT
JWT_SECRET=autospec-super-secret-jwt-key-2024
JWT_EXPIRES_IN=7d

# Gemini API (optional)
GEMINI_API_KEY=

# CORS
FRONTEND_URL=http://localhost:3000
